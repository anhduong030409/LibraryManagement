package control;

import java.io.IOException;
import java.util.List;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import dao.BookDAO;
import entity.BorrowTicket;

/**
 * Servlet này dùng để lấy danh sách phiếu mượn và hiển thị ra trang borrow-list.jsp
 */
@WebServlet("/borrow")
public class BorrowControl extends HttpServlet {
    private static final long serialVersionUID = 1L;

    protected void doGet(HttpServletRequest request, HttpServletResponse response) 
            throws ServletException, IOException {
        // Bước 1: Khởi tạo DAO
        BookDAO dao = new BookDAO();
        
        // Bước 2: Gọi hàm lấy danh sách từ Database (Hàm này mình sẽ bổ sung vào BookDAO ở dưới)
        List<BorrowTicket> list = dao.getAllBorrowTickets();
        
        // Bước 3: Đẩy danh sách này lên request để trang JSP có thể đọc được
        // Lưu ý: Tên "listB" phải khớp với tên trong thẻ <c:forEach items="${listB}" ...> ở file JSP
        request.setAttribute("listB", list);
        
        // Bước 4: Chuyển hướng (Forward) sang trang borrow-list.jsp
        request.getRequestDispatcher("borrow-list.jsp").forward(request, response);
    }

    protected void doPost(HttpServletRequest request, HttpServletResponse response) 
            throws ServletException, IOException {
        doGet(request, response);
    }
}