package control;

import java.io.IOException;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import dao.BookDAO;

/**
 * Servlet implementation class EditTicketControl
 */
@WebServlet("/editTicket")
public class EditTicketControl extends HttpServlet {
	private static final long serialVersionUID = 1L;
       
	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
	    // THÊM DÒNG NÀY ĐỂ KHÔNG LỖI TIẾNG VIỆT
	    request.setCharacterEncoding("UTF-8"); 
	    
	    int tid = Integer.parseInt(request.getParameter("tid"));
	    String dueDate = request.getParameter("dueDate");
	    String status = request.getParameter("status");

	    BookDAO dao = new BookDAO();
	    dao.updateTicket(tid, dueDate, status);
	    
	    // Sửa đường dẫn để quay về Servlet quản lý danh sách
	    response.sendRedirect("borrow"); 
	}
}
