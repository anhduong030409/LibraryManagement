package control;

import java.io.IOException;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import dao.BookDAO;

/**
 * Servlet implementation class DashboardServlet
 */
@WebServlet("/dashboard")
public class DashboardServlet extends HttpServlet {
	private static final long serialVersionUID = 1L;
	protected void doGet(HttpServletRequest request, HttpServletResponse response) 
	        throws ServletException, IOException {
	    BookDAO dao = new BookDAO();
	    
	    // Lấy các con số thống kê
	    int totalBooks = dao.getTotalBooks();
	    int activeTickets = dao.getActiveTickets();
	    int totalReaders = dao.getTotalReaders();
	    
	    // Đẩy dữ liệu sang JSP
	    request.setAttribute("totalBooks", totalBooks);
	    request.setAttribute("activeTickets", activeTickets);
	    request.setAttribute("totalReaders", totalReaders);
	    
	    request.getRequestDispatcher("dashboard.jsp").forward(request, response);
	}

}
