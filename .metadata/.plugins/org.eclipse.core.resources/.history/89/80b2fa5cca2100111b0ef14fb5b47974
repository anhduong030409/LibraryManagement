	// lấy dữ liệu từ database
	public List<BorrowTicket> getAllBorrowTickets() {
		List<BorrowTicket> list = new ArrayList<>();
		// SQL JOIN để lấy Fullname và Title thay vì ID
		String query = "SELECT t.id, r.fullname AS readerName, \r\n"
				+ "       GROUP_CONCAT(b.title SEPARATOR '<br>') AS bookTitle, \r\n"
				+ "       t.borrow_date AS borrowDate, t.due_date AS dueDate, t.status\r\n"
				+ "FROM borrow_tickets t\r\n"
				+ "JOIN readers r ON t.reader_id = r.id\r\n"
				+ "JOIN borrow_details d ON t.id = d.ticket_id\r\n"
				+ "JOIN books b ON d.book_id = b.id\r\n"
				+ "GROUP BY t.id, r.fullname, t.borrow_date, t.due_date, t.status;";
		try {
			Connection conn = new DBContext().getConnection();
			PreparedStatement ps = conn.prepareStatement(query);
			ResultSet rs = ps.executeQuery();
			while (rs.next()) {
				list.add(new BorrowTicket(rs.getInt(1), rs.getString(2), rs.getString(3), rs.getString(4),
						rs.getString(5), rs.getString(6)));
			}
		} catch (Exception e) {
			e.printStackTrace();
		}
		return list;
	}

