	// lấy dữ liệu từ database
	public List<BorrowTicket> getAllBorrowTickets() {
		List<BorrowTicket> list = new ArrayList<>();
		// SQL JOIN để lấy Fullname và Title thay vì ID
		String query = "SELECT t.id, r.fullname AS readerName, "
	            + "GROUP_CONCAT(b.title SEPARATOR '<br>') AS bookTitle, "
	            + "t.borrow_date, t.due_date, "
	            + "CASE "
	            + "    WHEN t.status = 'Đã trả' THEN 'Đã trả' "
	            + "    WHEN t.due_date < CURDATE() THEN 'Quá hạn' "
	            + "    ELSE 'Đang mượn' "
	            + "END AS current_status " // Tự động tính toán trạng thái
	            + "FROM borrow_tickets t "
	            + "JOIN readers r ON t.reader_id = r.id "
	            + "JOIN borrow_details d ON t.id = d.ticket_id "
	            + "JOIN books b ON d.book_id = b.id "
	            + "GROUP BY t.id, r.fullname, t.borrow_date, t.due_date, t.status;";
		try {
			Connection conn = new DBContext().getConnection();
			PreparedStatement ps = conn.prepareStatement(query);
			ResultSet rs = ps.executeQuery();
			while (rs.next()) {
				list.add(new BorrowTicket(rs.getInt(1), rs.getString(2), rs.getString(3), rs.getString(4),
						rs.getString(5), rs.getString(6)));
			}
		} catch (Exception e) {
			e.printStackTrace();
		}
		return list;
	}

