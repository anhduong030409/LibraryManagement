	// Đếm đồng thời số phiếu và số lượng sách đang mượn (Chưa trả)
	public int[] getActiveBorrowStats() {
	    int[] stats = {0, 0}; // stats[0]: số phiếu, stats[1]: số cuốn sách
	    // Join với bảng details để đếm tổng số bản ghi sách đang lưu hành
	    String query = "SELECT COUNT(DISTINCT t.id), COUNT(d.book_id) " +
	                   "FROM borrow_tickets t " +
	                   "JOIN borrow_details d ON t.id = d.ticket_id " +
	                   "WHERE t.status != N'Đã trả'";
	    try {
	        Connection conn = new DBContext().getConnection();
	        PreparedStatement ps = conn.prepareStatement(query);
	        ResultSet rs = ps.executeQuery();
	        if (rs.next()) {
	            stats[0] = rs.getInt(1);
	            stats[1] = rs.getInt(2);
	        }
	    } catch (Exception e) { 
	        e.printStackTrace(); 
	    }
	    return stats;
	}

