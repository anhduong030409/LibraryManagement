	// 2. Thực thi cập nhật phiếu mượn
	public void updateTicket(int tid, int rid, String ddate, String[] bids) {
	    Connection conn = null;
	    try {
	        conn = new DBContext().getConnection();
	        conn.setAutoCommit(false); // Bắt đầu giao dịch

	        // 1. HOÀN KHO: Lấy danh sách sách cũ để cộng lại số lượng trước khi xóa
	        String sqlGetOldBooks = "SELECT book_id FROM borrow_details WHERE ticket_id = ?";
	        PreparedStatement psOld = conn.prepareStatement(sqlGetOldBooks);
	        psOld.setInt(1, tid);
	        ResultSet rsOld = psOld.executeQuery();
	        
	        String sqlPlusQty = "UPDATE books SET quantity = quantity + 1 WHERE id = ?";
	        PreparedStatement psPlus = conn.prepareStatement(sqlPlusQty);
	        while (rsOld.next()) {
	            psPlus.setInt(1, rsOld.getInt("book_id"));
	            psPlus.addBatch();
	        }
	        psPlus.executeBatch();

	        // 2. CẬP NHẬT PHIẾU CHA: Độc giả và ngày trả
	        String sqlUpdateTicket = "UPDATE borrow_tickets SET reader_id = ?, due_date = ? WHERE id = ?";
	        PreparedStatement ps1 = conn.prepareStatement(sqlUpdateTicket);
	        ps1.setInt(1, rid);
	        ps1.setString(2, ddate);
	        ps1.setInt(3, tid);
	        ps1.executeUpdate();

	        // 3. XÓA CHI TIẾT CŨ
	        String sqlDeleteDetails = "DELETE FROM borrow_details WHERE ticket_id = ?";
	        PreparedStatement ps2 = conn.prepareStatement(sqlDeleteDetails);
	        ps2.setInt(1, tid);
	        ps2.executeUpdate();

	        // 4. CHÈN CHI TIẾT MỚI & TRỪ KHO MỚI
	        String sqlInsertDetail = "INSERT INTO borrow_details (ticket_id, book_id) VALUES (?, ?)";
	        String sqlMinusQty = "UPDATE books SET quantity = quantity - 1 WHERE id = ?";
	        
	        PreparedStatement psInsert = conn.prepareStatement(sqlInsertDetail);
	        PreparedStatement psMinus = conn.prepareStatement(sqlMinusQty);

	        for (String bId : bids) {
	            int bookId = Integer.parseInt(bId);
	            // Chèn vào bảng chi tiết
	            psInsert.setInt(1, tid);
	            psInsert.setInt(2, bookId);
	            psInsert.addBatch();
	            
	            // Trừ số lượng trong kho
	            psMinus.setInt(1, bookId);
	            psMinus.addBatch();
	        }
	        psInsert.executeBatch();
	        psMinus.executeBatch();

	        conn.commit(); // Xác nhận mọi thay đổi
	    } catch (Exception e) {
	        try { if(conn != null) conn.rollback(); } catch(Exception ex) {}
	        e.printStackTrace();
	    }
	}
	
