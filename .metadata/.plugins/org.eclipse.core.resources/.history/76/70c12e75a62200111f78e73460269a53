	public void insertMultipleBorrow(int rid, String[] bids, String bdate, String ddate) {
	    Connection conn = null;
	    try {
	        conn = new DBContext().getConnection();
	        conn.setAutoCommit(false); // Bắt đầu giao dịch để đảm bảo tính đồng bộ

	        // 1. Chèn vào bảng cha (borrow_tickets)
	        String sqlTicket = "INSERT INTO borrow_tickets (reader_id, borrow_date, due_date, status) VALUES (?, ?, ?, 'Đang mượn')";
	        PreparedStatement ps1 = conn.prepareStatement(sqlTicket, Statement.RETURN_GENERATED_KEYS);
	        ps1.setInt(1, rid);
	        ps1.setString(2, bdate);
	        ps1.setString(3, ddate);
	        ps1.executeUpdate();

	        // Lấy ID phiếu mượn vừa tự sinh ra
	        ResultSet rs = ps1.getGeneratedKeys();
	        int ticketId = 0;
	        if (rs.next()) ticketId = rs.getInt(1);

	        // 2. Chèn vào bảng con (borrow_details) VÀ Cập nhật kho sách (books)
	        String sqlDetail = "INSERT INTO borrow_details (ticket_id, book_id) VALUES (?, ?)";
	        String sqlUpdateQty = "UPDATE books SET quantity = quantity - 1 WHERE id = ?"; // Lệnh trừ kho
	        
	        PreparedStatement ps2 = conn.prepareStatement(sqlDetail);
	        PreparedStatement ps3 = conn.prepareStatement(sqlUpdateQty);

	        for (String bid : bids) {
	            int bookId = Integer.parseInt(bid);
	            
	            // Thêm vào chi tiết phiếu mượn
	            ps2.setInt(1, ticketId);
	            ps2.setInt(2, bookId);
	            ps2.addBatch();

	            // Giảm số lượng trong bảng books
	            ps3.setInt(1, bookId);
	            ps3.addBatch();
	        }
	        
	        ps2.executeBatch(); // Lưu toàn bộ chi tiết sách
	        ps3.executeBatch(); // Trừ kho toàn bộ sách

	        conn.commit(); // Hoàn tất giao dịch
	    } catch (Exception e) {
	        try { if(conn != null) conn.rollback(); } catch(Exception ex) {} // Lỗi thì hồi lại dữ liệu
	        e.printStackTrace();
	    }
	}
	//--------------------------------------------------
	//phương thức thực hiện đồng thời việc cập nhật trạng thái phiếu và tăng lại số lượng sách trong kho
	public void returnTicket(String tid) {
	    Connection conn = null;
	    try {
	        conn = new DBContext().getConnection();
	        conn.setAutoCommit(false); // Bắt đầu giao dịch (Transaction)

	        // 1. Cập nhật trạng thái phiếu mượn thành 'Đã trả'
	        String sqlUpdateTicket = "UPDATE borrow_tickets SET status = 'Đã trả' WHERE id = ?";
	        PreparedStatement ps1 = conn.prepareStatement(sqlUpdateTicket);
	        ps1.setString(1, tid);
	        ps1.executeUpdate();

	        // 2. Lấy danh sách ID sách thuộc phiếu mượn này để hoàn kho
	        String sqlGetBooks = "SELECT book_id FROM borrow_details WHERE ticket_id = ?";
	        PreparedStatement ps2 = conn.prepareStatement(sqlGetBooks);
	        ps2.setString(1, tid);
	        ResultSet rs = ps2.executeQuery();

	        // 3. Tăng số lượng (+1) cho từng đầu sách trong kho
	        String sqlUpdateQuantity = "UPDATE books SET quantity = quantity + 1 WHERE id = ?";
	        PreparedStatement ps3 = conn.prepareStatement(sqlUpdateQuantity);
	        while (rs.next()) {
	            ps3.setInt(1, rs.getInt("book_id"));
	            ps3.executeUpdate();
	        }

	        conn.commit(); // Xác nhận hoàn tất mọi thay đổi
	    } catch (Exception e) {
	        try { if (conn != null) conn.rollback(); } catch (Exception ex) {} // Lỗi thì quay lại trạng thái cũ
	        e.printStackTrace();
	    }
	}
	
