<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport"
	content="width=device-width, initial-scale=1, shrink-to-fit=no">
<title>Thư Viện Pro - Quản Lý Mượn/Trả</title>

<link
	href="${pageContext.request.contextPath}/vendor/fontawesome-free/css/all.min.css"
	rel="stylesheet" type="text/css">
<link
	href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
	rel="stylesheet">
<link href="${pageContext.request.contextPath}/css/sb-admin-2.min.css"
	rel="stylesheet">
<link
	href="${pageContext.request.contextPath}/vendor/datatables/dataTables.bootstrap4.min.css"
	rel="stylesheet">
<link rel="stylesheet"
	href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link href="${pageContext.request.contextPath}/css/sb-admin-2.min.css"
	rel="stylesheet">

<link
	href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
	rel="stylesheet" />

<link rel="stylesheet"
	href="https://cdn.jsdelivr.net/npm/@ttskch/select2-bootstrap4-theme@1.5.2/dist/select2-bootstrap4.min.css">

<style>
/* Fix lỗi chiều cao và căn lề trái cho placeholder */
.select2-container--bootstrap4 .select2-selection--multiple {
	min-height: 38px !important;
	padding: 0 0.5rem !important;
	display: block !important;
	/* Dùng block thay vì flex để input không bị đẩy ra giữa */
}

/* Fix lỗi các tag (choices) bị lệch và tràn */
.select2-container--bootstrap4 .select2-selection--multiple .select2-selection__rendered
	{
	display: flex !important;
	flex-wrap: wrap; /* Cho phép rớt dòng nếu chọn quá nhiều sách */
	padding: 0 !important;
	margin: 0 !important;
	list-style: none;
	align-items: center;
}

/* Đưa placeholder về sát lề trái chuẩn */
.select2-container--bootstrap4 .select2-selection--multiple .select2-search__field
	{
	margin-left: 0 !important;
	padding-left: 0 !important;
	text-align: left !important;
	height: 36px !important; /* Gần bằng chiều cao input chuẩn */
	width: 100% !important;
}

/* Fix màu sắc và khoảng cách cho các tag sách đã chọn */
.select2-container--bootstrap4 .select2-selection--multiple .select2-selection__choice
	{
	background-color: #4e73df !important;
	border: 1px solid #4e73df !important;
	color: white !important;
	margin: 4px 2px !important;
	padding: 2px 8px !important;
}

.select2-container--bootstrap4 .select2-selection--multiple .select2-selection__choice__remove
	{
	color: black !important;
	margin-right: 5px !important;
}
</style>
</head>

<body id="page-top">
	<div id="wrapper">
		<jsp:include page="sidebar.jsp"></jsp:include>
		<div id="content-wrapper" class="d-flex flex-column">
			<div id="content">
				<jsp:include page="navbar.jsp"></jsp:include>
				<div class="container-fluid">
					<div
						class="d-sm-flex align-items-center justify-content-between mb-4">
						<h1 class="h3 mb-0 text-gray-800">Quản Lý Mượn/Trả Sách</h1>
					</div>

					<div class="mb-4">
						<button type="button" class="btn btn-primary btn-icon-split"
							data-toggle="modal" data-target="#addTicketModal">
							<span class="icon text-white-50"> <i class="fas fa-plus"></i></span>
							<span class="text">Lập phiếu mượn mới</span>
						</button>
					</div>

					<div class="card shadow mb-4">
						<div class="card-header py-3">
							<h6 class="m-0 font-weight-bold text-primary">Danh sách giao
								dịch mượn/trả</h6>
						</div>
						<div class="card-body">
							<div class="table-responsive">
								<table class="table table-bordered" id="dataTable" width="100%"
									cellspacing="0">
									<thead>
										<tr>
											<th>Mã Phiếu</th>
											<th>Tên Độc Giả</th>
											<th>Tên Đầu Sách</th>
											<th>Ngày Mượn</th>
											<th>Hạn Trả</th>
											<th>Trạng Thái</th>
											<th>Thao Tác</th>
										</tr>
									</thead>
									<tbody>
										<c:forEach items="${listB}" var="o">
											<tr>
												<td>PM00${o.id}</td>
												<td>${o.readerName}</td>
												<td>${o.bookTitle}</td>
												<td>${o.borrowDate}</td>
												<td>${o.dueDate}</td>
												<td><span
													class="badge ${o.status == 'Đã trả' ? 'badge-success' : (o.status == 'Quá hạn' ? 'badge-danger' : 'badge-warning')}">
														${o.status} </span></td>
												<td class="text-nowrap">
													<div class="d-flex align-items-center" style="gap: 5px;">
														<%-- Nút Trả sách: Chỉ hiện khi chưa trả --%>
														<c:if test="${o.status != 'Đã trả'}">
															<a href="returnTicket?tid=${o.id}"
																class="btn btn-success btn-sm"
																onclick="return confirm('Xác nhận độc giả đã trả đủ sách?')">
																Trả sách </a>
														</c:if>

														<%-- Nút Sửa: Vô hiệu hóa nếu đã trả, hiện link nếu chưa trả --%>
														<c:choose>
															<c:when test="${o.status == 'Đã trả'}">
																<button class="btn btn-secondary btn-sm" disabled>Sửa</button>
															</c:when>
															<c:otherwise>
																<a href="loadTicket?tid=${o.id}"
																	class="btn btn-info btn-sm">Sửa</a>
															</c:otherwise>
														</c:choose>

														<%-- Nút Nhắc nhở: Chỉ hiện khi quá hạn --%>
														<c:if test="${o.status == 'Quá hạn'}">
															<button class="btn btn-warning btn-sm"
																onclick="showRemindModal('${o.id}', '${o.readerName}')">
																Nhắc nhở</button>
														</c:if>
													</div>
												</td>
											</tr>
										</c:forEach>
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
			</div>
			<jsp:include page="footer.jsp"></jsp:include>
		</div>
	</div>

	<div class="modal fade" id="addTicketModal" tabindex="-1" role="dialog"
		aria-hidden="true">
		<div class="modal-dialog modal-lg">
			<div class="modal-content">
				<div class="modal-header bg-primary text-white">
					<h5 class="modal-title">Lập Phiếu Mượn Mới</h5>
					<button type="button" class="close text-white" data-dismiss="modal"
						aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<form action="saveNewTicket" method="post">
					<div class="modal-body">
						<div class="form-group mb-3">
							<label class="fw-bold">Chọn Độc Giả:</label> <select name="rid"
								class="form-control" required>
								<c:forEach items="${listR}" var="r">
									<option value="${r.id}">${r.fullname}-${r.student_id}</option>
								</c:forEach>
							</select>
						</div>
						<div class="form-group mb-3">
							<label class="fw-bold">Chọn sách mượn (Tìm kiếm theo
								tên):</label> <select name="bid" id="bookSelect" class="form-control"
								multiple="multiple" style="width: 100%">
								<c:forEach items="${listBooks}" var="b">
									<option value="${b.id}">${b.title}</option>
								</c:forEach>
							</select>
						</div>
						<div class="row">
							<div class="col-md-6 mb-3">
								<label class="fw-bold">Ngày mượn:</label> <input type="text"
									name="bdate" id="bdate" class="form-control date-input"
									required>
							</div>
							<div class="col-md-6 mb-3">
								<label class="fw-bold">Hạn trả:</label> <input type="text"
									name="ddate" id="ddate" class="form-control date-input"
									required>
							</div>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary"
							data-dismiss="modal">Hủy</button>
						<button type="submit" class="btn btn-primay">Xác nhận
							lập phiếu</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<div class="modal fade" id="remindModal" tabindex="-1" role="dialog"
		aria-hidden="true">
		<div class="modal-dialog" role="document">
			<div class="modal-content">
				<div class="modal-header bg-warning text-white">
					<h5 class="modal-title">Thông báo nhắc nhở trả sách</h5>
					<button type="button" class="close" data-dismiss="modal"
						aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<p>
						<strong>Độc giả:</strong> <span id="remindReaderName"></span>
					</p>
					<p>
						<strong>Mã phiếu:</strong> <span id="remindTicketId"></span>
					</p>
					<hr>
					<div class="form-group">
						<label>Nội dung tin nhắn mẫu:</label>
						<textarea class="form-control" id="remindMessage" rows="5"
							readonly>
Chào bạn, thư viện thông báo phiếu mượn mã [ID] của bạn đã quá hạn. 
Vui lòng hoàn trả sách sớm để tránh phát sinh phí phạt. Xin cảm ơn!</textarea>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary"
						data-dismiss="modal">Đóng</button>
					<button type="button" class="btn btn-primary"
						onclick="copyMessage()">Copy tin nhắn</button>
				</div>
			</div>
		</div>
	</div>

	<script
		src="${pageContext.request.contextPath}/vendor/jquery/jquery.min.js"></script>

	<script
		src="${pageContext.request.contextPath}/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

	<script src="${pageContext.request.contextPath}/js/sb-admin-2.min.js"></script>

	<script
		src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

	<script
		src="${pageContext.request.contextPath}/vendor/datatables/jquery.dataTables.min.js"></script>
	<script
		src="${pageContext.request.contextPath}/vendor/datatables/dataTables.bootstrap4.min.js"></script>

	<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

	<script>
		$(document)
				.ready(
						function() {
							// Khởi tạo Select2 (Giải quyết lỗi hình 1)
							$(document)
									.ready(
											function() {
												$('#bookSelect')
														.select2(
																{
																	theme : 'bootstrap4', // Ép sử dụng theme bootstrap 4 để fix lỗi hình 1
																	placeholder : "Gõ tên sách để chọn...",
																	allowClear : true,
																	width : '100%', // Đảm bảo luôn full chiều ngang form
																	dropdownParent : $('#addTicketModal'), // Fix lỗi không gõ được chữ trên Modal
																	containerCssClass : ':all:', // Giữ nguyên các class CSS của Bootstrap
																});

												// Fix lỗi hiển thị khi mở Modal (Đảm bảo nó render lại đúng kích thước)
												$('#addTicketModal')
														.on(
																'shown.bs.modal',
																function() {
																	$(
																			'#bookSelect')
																			.select2(
																					'open')
																			.select2(
																					'close');
																});
											});

							// Khởi tạo DataTable (Giải quyết lỗi hình 2)
							if ($('#dataTable').length
									&& !$.fn.DataTable
											.isDataTable('#dataTable')) {
								$('#dataTable')
										.DataTable(
												{
													"language" : {
														"sSearch" : "Tìm kiếm:",
														"sLengthMenu" : "Xem _MENU_ mục",
														"sInfo" : "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
														"oPaginate" : {
															"sNext" : "Tiếp",
															"sPrevious" : "Trước"
														}
													}
												});
							}

							// Khởi tạo Flatpickr
							flatpickr(".date-input", {
								dateFormat : "Y-m-d",
								altInput : true,
								altFormat : "d/m/Y",
								defaultDate : "today"
							});
						});
	</script>

	<script>
		function showRemindModal(id, name) {
			// Điền dữ liệu vào modal
			$('#remindTicketId').text(id);
			$('#remindReaderName').text(name);

			// Cập nhật mã ID vào mẫu tin nhắn
			let message = "Chào " + name + ", thư viện nhắc bạn phiếu mượn #"
					+ id + " đã quá hạn. Vui lòng trả sách sớm nhé!";
			$('#remindMessage').val(message);

			// Hiển thị modal
			$('#remindModal').modal('show');
		}

		function copyMessage() {
			let copyText = document.getElementById("remindMessage");
			copyText.select();
			copyText.setSelectionRange(0, 99999); // Cho điện thoại
			document.execCommand("copy");

			alert("Đã copy nội dung nhắc nhở!");
		}
	</script>
</body>
</html>